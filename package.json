{
  "name": "loopback-workspace",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp run dev",
    "dev:server": "pnpm --filter @loopback/server dev",
    "build": "vp run build",
    "check": "vp run check",
    "test": "vp test",
    "lint": "vp lint",
    "fmt": "vp fmt",
    "typecheck": "tsc --build",
    "start": "node packages/cli/dist/index.js start",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "lefthook": "^2.1.4",
    "typescript": "^5.7.0",
    "vite-plus": "^0.1.0"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "lefthook"
    ]
  }
}
